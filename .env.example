# Copy this file to ".env" and fill in your values, OR set these as real
# environment variables. NEVER commit your actual .env file (it is gitignored).

# Your Anthropic API key — enables the live AI chatbot ("Terra").
# Get one at https://console.anthropic.com/ . Without it, the app still runs
# and the chatbot uses a built-in keyword fallback.
ANTHROPIC_API_KEY=

# Optional: override the Claude model used for chat (defaults to claude-opus-4-8).
# GREENCITY_MODEL=claude-opus-4-8

# Optional: server port (defaults to 5000).
# PORT=5000

# Optional: set to 1 to enable Flask debug mode (development only — never in prod).
# FLASK_DEBUG=0
