# Copy this file to ".env" and fill in your values, OR set these as real
# environment variables. NEVER commit your actual .env file (it is gitignored).
#
# The AI chatbot picks a provider in this order: Groq -> Claude -> offline.
# Set at least one key to enable live AI; with none, a keyword fallback is used.

# --- Groq (primary, recommended: fast & free tier) ---
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=
# Optional model override (default: llama-3.3-70b-versatile)
# GROQ_MODEL=llama-3.3-70b-versatile

# --- Anthropic / Claude (optional alternative) ---
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Optional model override (default: claude-opus-4-8)
# GREENCITY_MODEL=claude-opus-4-8

# --- Server ---
# PORT=5000
# FLASK_DEBUG=0
